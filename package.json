{
  "name": "hiero-message-box",
  "homepage": "https://github.com/InternetOfPeers/hiero-message-box",
  "version": "1.0.0",
  "description": "Simple encrypted messaging system for Hedera accounts",
  "license": "MIT",
  "author": "Giuseppe Bertone <giuseppe.bertone@proton.me>",
  "type": "commonjs",
  "scripts": {
    "start": "npm run setup-message-box && sleep 5 && npm run listen-for-new-messages",
    "setup-message-box": "node src/setup-message-box.js",
    "link-message-box": "node src/link-message-box.js",
    "listen-for-new-messages": "node src/listen-for-new-messages.js",
    "check-messages": "node src/check-messages.js",
    "send-message": "node src/send-message.js",
    "remove-message-box": "node src/remove-message-box.js",
    "format": "prettier --write \"src/**/*.js\"",
    "test:unit": "node test/unit.test.js",
    "test:integration": "node test/integration.test.js",
    "test": "node test/unit.test.js && node test/integration.test.js"
  },
  "dependencies": {
    "@hiero-ledger/sdk": "^2.80.0"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
