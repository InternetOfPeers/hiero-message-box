{
  "name": "hiero-message-box-monorepo",
  "private": true,
  "workspaces": [
    "hiero-message-box-lib",
    "hiero-message-box-cli",
    "hiero-message-box-web"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "test:lib": "npm test -w @internetofpeers/hiero-message-box",
    "test:lib:unit": "npm run test:unit -w @internetofpeers/hiero-message-box",
    "test:cli": "npm test -w @internetofpeers/hiero-message-box-cli",
    "test:integration": "npm run test:integration -w @internetofpeers/hiero-message-box",
    "test:coverage": "npm run test:coverage --workspaces --if-present",
    "test:coverage:lib": "npm run test:coverage -w @internetofpeers/hiero-message-box",
    "test:coverage:cli": "npm run test:coverage -w @internetofpeers/hiero-message-box-cli",
    "format": "prettier --write \"**/*.{js,vue,json}\" --ignore-path .prettierignore"
  },
  "devDependencies": {
    "prettier": "^3.8.1"
  }
}
